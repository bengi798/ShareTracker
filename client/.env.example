# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Found in Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_
CLERK_SECRET_KEY=sk_live_

# Clerk routing (these defaults match the current app routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/complete-profile

# ── Backend API ───────────────────────────────────────────────────────────────
# URL of the ASP.NET Core API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:5297/api

# ── EODHD Market Data ─────────────────────────────────────────────────────────
# Found at https://eodhd.com/cp/settings → API Tokens
# Used for forex rates in the Next.js API route
NEXT_PUBLIC_EODHD_API_KEY=your_eodhd_api_key_here
